generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. METADATA LAYER (erp_meta)
// The "Brain" of the ERP representing how data behaves
// ==========================================

model MetaEntity {
  id          Int         @id @default(autoincrement())
  entityName  String      @unique @map("entity_name")
  tableName   String      @map("table_name")
  fields      MetaField[]
  
  @@map("meta_entity")
}

model MetaField {
  id          Int         @id @default(autoincrement())
  entityId    Int         @map("entity_id")
  entity      MetaEntity  @relation(fields: [entityId], references: [id])
  fieldName   String      @map("field_name")
  dataType    String      @map("data_type") // e.g., string, number, date, lookup
  source      String      // e.g., master, txn, derived
  uiControl   String      @map("ui_control") // e.g., text, dropdown, datepicker
  required    Boolean     @default(false)
  
  voucherFields MetaVoucherField[]
  extValues     ExtEntityValue[]

  @@unique([entityId, fieldName])
  @@map("meta_field")
}

model MetaTagMapping {
  id          Int     @id @default(autoincrement())
  companyId   Int?    @map("company_id") // Null means global
  entityName  String  @map("entity_name")
  defaultName String  @map("default_name")
  displayName String  @map("display_name")

  @@unique([companyId, entityName])
  @@map("meta_tag_mapping")
}

model MetaVoucherDefinition {
  id          Int     @id @default(autoincrement())
  voucherType String  @unique @map("voucher_type")
  module      String  

  fields      MetaVoucherField[]

  @@map("meta_voucher_definition")
}

// Maps dynamic fields to specific voucher types
model MetaVoucherField {
  id              Int                   @id @default(autoincrement())
  voucherId       Int                   @map("voucher_id")
  voucherDef      MetaVoucherDefinition @relation(fields: [voucherId], references: [id])
  fieldId         Int                   @map("field_id")
  metaField       MetaField             @relation(fields: [fieldId], references: [id])
  
  @@unique([voucherId, fieldId])
  @@map("meta_voucher_fields")
}

// ==========================================
// 2. MASTER DATA LAYER (erp_master)
// ==========================================

model MstCompany {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  alias       String?
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   Int?     @map("created_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branches    MstBranch[]
  departments MstDepartment[]
  users       MstUser[]
  roles       SecRole[]

  @@map("mst_company")
}

model MstBranch {
  id          Int        @id @default(autoincrement())
  companyId   Int        @map("company_id")
  company     MstCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code        String     
  name        String
  type        String     @default("office") // office, warehouse, factory
  alias       String?
  status      String     @default("active")
  createdAt   DateTime   @default(now()) @map("created_at")
  createdBy   Int?       @map("created_by")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  departments MstDepartment[]
  users       MstUser[]

  @@unique([companyId, code])
  @@map("mst_branch")
}

model MstDepartment {
  id          Int        @id @default(autoincrement())
  companyId   Int        @map("company_id")
  company     MstCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId    Int        @map("branch_id")
  branch      MstBranch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  code        String
  name        String
  alias       String?
  status      String     @default("active")
  createdAt   DateTime   @default(now()) @map("created_at")
  createdBy   Int?       @map("created_by")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  users       MstUser[]

  @@unique([branchId, code])
  @@map("mst_department")
}

model MstUser {
  id            Int        @id @default(autoincrement())
  companyId     Int        @map("company_id")
  company       MstCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId      Int?       @map("branch_id")
  branch        MstBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  departmentId  Int?       @map("department_id")
  department    MstDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  
  email         String     @unique
  username      String     @unique
  firstName     String     @map("first_name")
  lastName      String     @map("last_name")
  phoneNumber   String?    @map("phone_number")
  passwordHash  String?    @map("password_hash")
  status        String     @default("active")
  createdAt     DateTime   @default(now()) @map("created_at")
  createdBy     Int?       @map("created_by")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  // Security relations
  userRoles   SecUserRole[]
  dataScopes  SecUserDataScope[]
  auditLogs   SecAuditLog[]
  approvals   WfApproval[]
  notifications Notification[]

  @@map("mst_user")
}

model MstProduct {
  id            Int      @id @default(autoincrement())
  companyId     Int      @map("company_id")
  code          String
  name          String
  alias         String?
  description   String?
  categoryId    Int?     @map("category_id")
  category      MstCategory? @relation(fields: [categoryId], references: [id])
  unitId        Int?     @map("unit_id")
  unit          MstUnit? @relation(fields: [unitId], references: [id])
  hsnCode       String?  @map("hsn_code")     // HSN/SAC code for tax
  taxRate       Decimal? @map("tax_rate") @db.Decimal(5, 2)
  purchasePrice Decimal? @map("purchase_price") @db.Decimal(18, 2)
  sellingPrice  Decimal? @map("selling_price") @db.Decimal(18, 2)
  reorderLevel  Decimal? @map("reorder_level") @db.Decimal(18, 4)
  reorderQty    Decimal? @map("reorder_qty") @db.Decimal(18, 4)
  trackBatch    Boolean  @default(false) @map("track_batch")
  trackSerial   Boolean  @default(false) @map("track_serial")
  extraData     Json?    @map("extra_data")  // JSONB for dynamic custom fields
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     Int?     @map("created_by")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([companyId, categoryId])
  @@map("mst_product")
}

model MstAccount {
  id            Int      @id @default(autoincrement())
  companyId     Int      @map("company_id")
  code          String
  name          String
  alias         String?
  accountType   String   @map("account_type") // ASSET, LIABILITY, EQUITY, INCOME, EXPENSE
  parentId      Int?     @map("parent_id")
  parent        MstAccount?  @relation("AccountTree", fields: [parentId], references: [id])
  children      MstAccount[] @relation("AccountTree")
  level         Int      @default(0)
  isGroup       Boolean  @default(false) @map("is_group") // Group accounts can't post directly
  subledgerType String?  @map("subledger_type") // CUSTOMER, VENDOR, BANK, CASH, null
  openingBalance Decimal @default(0) @map("opening_balance") @db.Decimal(18, 2)
  currencyCode  String   @default("INR") @map("currency_code")
  extraData     Json?    @map("extra_data")
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     Int?     @map("created_by")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([companyId, code])
  @@index([companyId, accountType])
  @@index([companyId, parentId])
  @@map("mst_account")
}

model MstWarehouse {
  id            Int      @id @default(autoincrement())
  companyId     Int      @map("company_id")
  branchId      Int      @map("branch_id")
  code          String
  name          String
  alias         String?
  type          String   @default("main") // main, transit, scrap, production
  address       String?
  extraData     Json?    @map("extra_data")
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     Int?     @map("created_by")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([companyId, code])
  @@index([companyId, branchId])
  @@map("mst_warehouse")
}

model MstUnit {
  id             Int      @id @default(autoincrement())
  companyId      Int      @map("company_id")
  code           String
  name           String
  symbol         String
  decimalPlaces  Int      @default(2) @map("decimal_places")
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      Int?     @map("created_by")
  updatedAt      DateTime @updatedAt @map("updated_at")

  products       MstProduct[]

  @@unique([companyId, code])
  @@map("mst_unit")
}

model MstCategory {
  id            Int      @id @default(autoincrement())
  companyId     Int      @map("company_id")
  code          String
  name          String
  module        String   @default("item") // item, account, etc.
  parentId      Int?     @map("parent_id")
  parent        MstCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children      MstCategory[] @relation("CategoryTree")
  level         Int      @default(0)
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     Int?     @map("created_by")
  updatedAt     DateTime @updatedAt @map("updated_at")

  products      MstProduct[]

  @@unique([companyId, module, code])
  @@index([companyId, module])
  @@map("mst_category")
}

// ==========================================
// 3. DYNAMIC EXTENSION STORAGE (U00x Replacement)
// ==========================================

model ExtEntityValue {
  id          Int        @id @default(autoincrement())
  entityName  String     @map("entity_name") // e.g., 'mst_product', 'txn_voucher'
  entityId    Int        @map("entity_id")   // The actual row ID in the entity's table
  fieldId     Int        @map("field_id")
  metaField   MetaField  @relation(fields: [fieldId], references: [id])
  value       String     // Stored as string, casted dynamically at runtime based on metaField.dataType

  @@unique([entityName, entityId, fieldId])
  @@map("ext_entity_values")
}

// ==========================================
// 4. TRANSACTION LAYER (erp_txn)
// ==========================================
// ==========================================
// 7. WORKFLOW ENGINE (erp_workflow)
// ==========================================

model WfDefinition {
  id          Int       @id @default(autoincrement())
  name        String
  entityType  String    @map("entity_type")  // e.g. VOUCHER
  voucherType String?   @map("voucher_type") // e.g. SALES_INVOICE
  companyId   Int?      @map("company_id")
  isActive    Boolean   @default(true) @map("is_active")
  
  stages      WfStage[]
  instances   WfInstance[]

  @@map("wf_definition")
}

model WfStage {
  id           Int       @id @default(autoincrement())
  workflowId   Int       @map("workflow_id")
  workflow     WfDefinition @relation(fields: [workflowId], references: [id])
  name         String
  sequence     Int       // Order of execution
  actorType    String    @map("actor_type") // USER, ROLE, DEPARTMENT, DYNAMIC
  actorValue   String?   @map("actor_value") // e.g. role name, user id
  allowEdit    Boolean   @default(false) @map("allow_edit")
  autoPost     Boolean   @default(false) @map("auto_post")
  approvalMode String    @default("ANY") @map("approval_mode") // ANY or ALL for parallel approvals

  fromTransitions WfTransition[] @relation("FromStage")
  toTransitions   WfTransition[] @relation("ToStage")
  instances       WfInstance[]
  approvals       WfApproval[]
  escalations     WfEscalation[]

  @@map("wf_stage")
}

model WfTransition {
  id            Int       @id @default(autoincrement())
  fromStageId   Int       @map("from_stage_id")
  fromStage     WfStage   @relation("FromStage", fields: [fromStageId], references: [id])
  toStageId     Int       @map("to_stage_id")
  toStage       WfStage   @relation("ToStage", fields: [toStageId], references: [id])
  action        String    // APPROVE, REJECT
  conditionJson Json?     @map("condition_json") // e.g. {"totalAmount": "> 10000"}

  @@map("wf_transition")
}

model WfInstance {
  id              Int       @id @default(autoincrement())
  workflowId      Int       @map("workflow_id")
  workflow        WfDefinition @relation(fields: [workflowId], references: [id])
  entityId        Int       @map("entity_id") // ID of the voucher/record
  entityType      String    @map("entity_type") // Table name / type
  currentStageId  Int       @map("current_stage_id")
  currentStage    WfStage   @relation(fields: [currentStageId], references: [id])
  status          String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, REJECTED
  
  history         WfHistory[]
  approvals       WfApproval[]

  @@index([entityType, entityId])
  @@index([currentStageId])
  @@map("wf_instance")
}

model WfHistory {
  id            Int       @id @default(autoincrement())
  instanceId    Int       @map("instance_id")
  instance      WfInstance @relation(fields: [instanceId], references: [id])
  action        String    // e.g. SUBMIT, APPROVE, REJECT
  userId        Int       @map("user_id")
  comments      String?
  timestamp     DateTime  @default(now())

  @@map("wf_history")
}

model WfApproval {
  id            Int       @id @default(autoincrement())
  instanceId    Int       @map("instance_id")
  instance      WfInstance @relation(fields: [instanceId], references: [id])
  currentStageId Int      @map("current_stage_id")
  stage         WfStage   @relation(fields: [currentStageId], references: [id])
  userId        Int       @map("user_id")
  user          MstUser   @relation(fields: [userId], references: [id])
  status        String    @default("PENDING") // PENDING, APPROVED, REJECTED
  comments      String?
  approvedAt    DateTime? @map("approved_at")

  @@unique([instanceId, currentStageId, userId])
  @@index([instanceId, status])
  @@map("wf_approval")
}

model WfEscalation {
  id            Int       @id @default(autoincrement())
  stageId       Int       @map("stage_id")
  stage         WfStage   @relation(fields: [stageId], references: [id], onDelete: Cascade)
  timeoutMinutes Int      @map("timeout_minutes")
  escalateToUserId Int?   @map("escalate_to_user_id")
  escalateToRoleId Int?   @map("escalate_to_role_id")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("wf_escalation")
}

model Notification {
  id            Int       @id @default(autoincrement())
  type          String    // WORKFLOW_ACTION, WORKFLOW_AWAITING_APPROVAL, WORKFLOW_REJECTED, etc.
  recipientId   Int       @map("recipient_id")
  recipient     MstUser   @relation(fields: [recipientId], references: [id])
  entityType    String?   @map("entity_type")
  entityId      Int?      @map("entity_id")
  messageTemplate String  @map("message_template")
  messageData   Json?     @map("message_data") // Additional context
  channelType   String    @default("IN_APP") @map("channel_type") // IN_APP, EMAIL, SMS, PUSH
  isRead        Boolean   @default(false) @map("is_read")
  readAt        DateTime? @map("read_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  expiresAt     DateTime? @map("expires_at") // Auto-cleanup

  @@index([recipientId, isRead])
  @@index([createdAt])
  @@map("notification")
}

// ==========================================
// 8. SECURITY & PERMISSION MODEL
// ==========================================

model SecRole {
  id          Int        @id @default(autoincrement())
  companyId   Int        @map("company_id")
  company     MstCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code        String
  name        String
  description String?
  hierarchyLevel Int    @default(0) @map("hierarchy_level")
  status      String     @default("active")
  createdAt   DateTime   @default(now()) @map("created_at")
  createdBy   Int?       @map("created_by")

  users       SecUserRole[]
  permissions SecRolePermission[]
  entityPermissions SecEntityPermission[]
  fieldPermissions SecFieldPermission[]

  @@unique([companyId, code])
  @@map("sec_role")
}

model SecPermission {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  module      String
  isActive    Boolean  @default(true) @map("is_active")

  roles       SecRolePermission[]

  @@map("sec_permission")
}

model SecUserRole {
  id     Int    @id @default(autoincrement())
  userId Int    @map("user_id")
  user   MstUser @relation(fields: [userId], references: [id])
  roleId Int    @map("role_id")
  role   SecRole @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("sec_user_role")
}

model SecRolePermission {
  id           Int            @id @default(autoincrement())
  roleId       Int            @map("role_id")
  role         SecRole        @relation(fields: [roleId], references: [id])
  permissionId Int            @map("permission_id")
  permission   SecPermission  @relation(fields: [permissionId], references: [id])
  allowed      Boolean        @default(true)

  @@unique([roleId, permissionId])
  @@map("sec_role_permission")
}

model SecEntityPermission {
  id       Int     @id @default(autoincrement())
  roleId   Int     @map("role_id")
  role     SecRole @relation(fields: [roleId], references: [id])
  entity   String  // e.g., SALES_VOUCHER, PRODUCT
  canCreate Boolean @default(false) @map("can_create")
  canRead   Boolean @default(true)  @map("can_read")
  canUpdate Boolean @default(false) @map("can_update")
  canDelete Boolean @default(false) @map("can_delete")

  @@unique([roleId, entity])
  @@map("sec_entity_permission")
}

model SecFieldPermission {
  id       Int     @id @default(autoincrement())
  roleId   Int     @map("role_id")
  role     SecRole @relation(fields: [roleId], references: [id])
  entity   String
  fieldName String @map("field_name")
  canEdit  Boolean @default(true)  @map("can_edit")
  canView  Boolean @default(true)  @map("can_view")

  @@unique([roleId, entity, fieldName])
  @@map("sec_field_permission")
}

model SecUserDataScope {
  id        Int  @id @default(autoincrement())
  userId    Int  @map("user_id")
  user      MstUser @relation(fields: [userId], references: [id])
  companyId Int  @map("company_id")
  branchId  Int? @map("branch_id")
  deptId    Int? @map("dept_id")

  @@unique([userId, companyId, branchId, deptId])
  @@map("sec_user_data_scope")
}

model SecAuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      MstUser  @relation(fields: [userId], references: [id])
  entity    String
  entityId  Int      @map("entity_id")
  action    String   // CREATE, UPDATE, DELETE, VIEW
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  timestamp DateTime @default(now())
  ipAddress String?  @map("ip_address")

  @@index([userId, entity, timestamp])
  @@map("sec_audit_log")
}

// ==========================================
// 9. CONFIGURATION FRAMEWORK
// ==========================================

model CfgConfig {
  id        Int      @id @default(autoincrement())
  companyId Int?     @map("company_id") // null = global
  module    String
  configKey String   @map("config_key")
  configValue Json   @map("config_value")
  dataType  String   @default("string") @map("data_type")
  isActive  Boolean  @default(true) @map("is_active")

  @@unique([companyId, module, configKey])
  @@map("cfg_config")
}

model CfgTagMapping {
  id          Int     @id @default(autoincrement())
  companyId   Int?    @map("company_id") // null = global
  entityName  String  @map("entity_name")
  defaultName String  @map("default_name")
  displayName String  @map("display_name")
  pluralName  String? @map("plural_name")
  module      String?

  @@unique([companyId, entityName])
  @@map("cfg_tag_mapping")
}

// ==========================================
// 10. NUMBER SEQUENCES
// ==========================================

model SeqNumberSequence {
  id             Int      @id @default(autoincrement())
  companyId      Int      @map("company_id")
  branchId       Int?     @map("branch_id")
  voucherType    String   @map("voucher_type")
  prefix         String
  pattern        String   // e.g., {PREFIX}-{BRANCH}-{YYYY}-{####}
  financialYear  String   @map("financial_year")
  lastNumber     Int      @default(0) @map("last_number")
  padLength      Int      @default(4) @map("pad_length")
  isActive       Boolean  @default(true) @map("is_active")

  @@unique([companyId, branchId, voucherType, financialYear])
  @@map("seq_number_sequence")
}
model TxnVoucherHeader {
  id           Int              @id @default(autoincrement())
  voucherNo    String?          @map("voucher_no")
  voucherType  String           @map("voucher_type")
  companyId    Int              @map("company_id")
  branchId     Int              @map("branch_id")
  voucherDate  DateTime         @map("voucher_date")
  status       String           @default("DRAFT")
  totalAmount  Decimal          @map("total_amount") @db.Decimal(18, 2)
  jsonPayload  Json?            @map("json_payload")
  
  items        TxnVoucherItem[]
  ledgerEntries AccLedgerEntry[]

  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([companyId, voucherDate])
  @@index([voucherType])
  @@index([branchId])
  @@map("txn_voucher_header")
}

model TxnVoucherItem {
  id           Int              @id @default(autoincrement())
  voucherId    Int              @map("voucher_id")
  voucher      TxnVoucherHeader @relation(fields: [voucherId], references: [id])
  productId    Int              @map("product_id")
  qty          Decimal          @db.Decimal(18, 4)
  rate         Decimal          @db.Decimal(18, 4)
  amount       Decimal          @db.Decimal(18, 2)
  batchId      String?          @map("batch_id")
  serialId     String?          @map("serial_id")

  @@map("txn_voucher_items")
}

// ==========================================
// 5. ACCOUNTING LEDGER (erp_accounting)
// ==========================================

model AccLedgerEntry {
  id           Int              @id @default(autoincrement())
  voucherId    Int              @map("voucher_id")
  voucher      TxnVoucherHeader @relation(fields: [voucherId], references: [id])
  accountId    Int              @map("account_id")
  debit        Decimal          @default(0) @db.Decimal(18, 2)
  credit       Decimal          @default(0) @db.Decimal(18, 2)
  postingDate  DateTime         @map("posting_date")

  @@index([accountId, postingDate])
  @@map("acc_ledger_entry")
}

// ==========================================
// 6. INVENTORY LEDGER (erp_inventory)
// ==========================================

model InvStockLedger {
  id           Int              @id @default(autoincrement())
  productId    Int              @map("product_id")
  warehouseId  Int              @map("warehouse_id")
  qtyIn        Decimal          @default(0) @map("qty_in") @db.Decimal(18, 4)
  qtyOut       Decimal          @default(0) @map("qty_out") @db.Decimal(18, 4)
  batchId      String?          @map("batch_id")
  serialId     String?          @map("serial_id")
  voucherRef   Int              @map("voucher_ref")

  @@index([productId, warehouseId])
  @@index([batchId])
  @@map("inv_stock_ledger")
}
